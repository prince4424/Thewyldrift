# Copy to backend/.env and fill in secrets (this file is safe to commit).
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:8080
# Atlas: the segment AFTER .net/ is the database name (must match Compass, e.g. thewyldrift).
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/thewyldrift?retryWrites=true&w=majority
# Wrong: ...mongodb.net/?... or ...mongodb.net (often defaults to "test" → empty products).
MONGODB_URI=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ADMIN_PASSKEY=1234567899
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Optional: shown in / and 404 JSON when SERVE_STATIC is off (Vite default is http://localhost:5173).
# FRONTEND_DEV_URL=http://localhost:5173

# Optional: set to 1 only if this Node process should also serve frontend/dist (after npm run build in ../frontend).
# SERVE_STATIC=1
